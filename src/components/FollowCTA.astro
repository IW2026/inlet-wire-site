---
// Inlet Wire — Follow CTA block
// Drop <FollowCTA /> anywhere to show the follow bar.
---
<div class="follow-cta">
  <span class="follow-cta-label">Follow Inlet Wire</span>
  <div class="follow-cta-btns">
    <a
      class="follow-btn"
      href="https://open.spotify.com/show/2BTlbhjjXBsV6MECUSUWwY"
      target="_blank"
      rel="noopener"
      aria-label="Follow on Spotify"
    >
      <img class="follow-btn-icon" src="https://cdn.simpleicons.org/spotify/0A0A0A" alt="" aria-hidden="true" />
      Spotify
    </a>
    <a
      class="follow-btn"
      href="https://podcasts.apple.com/podcast/id1876137985"
      target="_blank"
      rel="noopener"
      aria-label="Subscribe on Apple Podcasts"
    >
      <img class="follow-btn-icon" src="https://cdn.simpleicons.org/applepodcasts/0A0A0A" alt="" aria-hidden="true" />
      Apple Podcasts
    </a>
    <a
      class="follow-btn"
      href="https://www.youtube.com/inletwire"
      target="_blank"
      rel="noopener"
      aria-label="Subscribe on YouTube"
    >
      <img class="follow-btn-icon" src="https://cdn.simpleicons.org/youtube/0A0A0A" alt="" aria-hidden="true" />
      YouTube
    </a>
    <a
      class="follow-btn"
      href="https://www.instagram.com/inletwire"
      target="_blank"
      rel="noopener"
      aria-label="Follow on Instagram"
    >
      <img class="follow-btn-icon" src="https://cdn.simpleicons.org/instagram/0A0A0A" alt="" aria-hidden="true" />
      Instagram
    </a>
    <a
      class="follow-btn"
      href="https://www.facebook.com/inletwire"
      target="_blank"
      rel="noopener"
      aria-label="Follow on Facebook"
    >
      <img class="follow-btn-icon" src="https://cdn.simpleicons.org/facebook/0A0A0A" alt="" aria-hidden="true" />
      Facebook
    </a>
  </div>
</div>
