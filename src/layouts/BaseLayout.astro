---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
  /** Alt text for the OG/Twitter share image. Defaults to the page title. */
  ogImageAlt?: string;
  ogType?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  /**
   * Absolute or root-relative URL of the page's LCP image. When set,
   * emits <link rel="preload" as="image" fetchpriority="high"> so the
   * browser starts fetching before layout begins.
   */
  preloadImage?: string;
  /**
   * Optional WebP variant of the preload image. WebP-capable browsers
   * will preload this via imagesrcset instead of the JPEG fallback.
   */
  preloadImageWebp?: string;
  /** Set true on utility/legal pages to suppress indexing. */
  noindex?: boolean;
  // Article-specific Open Graph meta — only emitted when ogType="article"
  articlePublishedTime?: string;  // ISO 8601
  articleModifiedTime?: string;   // ISO 8601
  articleAuthor?: string;         // URL
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = "Inlet Wire is a Canadian music podcast hosted by Eric Chan — your direct line to BC artists. Weekly conversations with the independent artists shaping the sound of British Columbia.",
  path = "/",
  ogImage = "/og-default.png",
  ogImageAlt,
  ogType = "website",
  jsonLd,
  preloadImage,
  preloadImageWebp,
  noindex = false,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags,
} = Astro.props;

const siteTitle = "Inlet Wire";
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonical = Astro.site ? new URL(path, Astro.site).toString() : path;
const absoluteOg = Astro.site ? new URL(ogImage, Astro.site).toString() : ogImage;
const resolvedOgAlt = ogImageAlt ?? fullTitle;

const jsonLdArray = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---
<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Eric Chan" />
    <meta name="theme-color" content="#000000" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en-CA" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/logo.png" sizes="any" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- Social profile verification -->
    <link rel="me" href="https://www.instagram.com/inletwire" />
    <link rel="me" href="https://www.youtube.com/@inletwire" />
    <link rel="me" href="https://open.spotify.com/show/2BTlbhjjXBsV6MECUSUWwY" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="rz2EugUPxHNBkIflcXZLk7iWnngmMX22puEQ2l3KtIM" />
    <meta name="msvalidate.01" content="D8DF4BC12590B3F7C89D5C6A7E6664A6" />

    {preloadImage && preloadImageWebp && (
      <link
        rel="preload"
        as="image"
        href={preloadImageWebp}
        type="image/webp"
        fetchpriority="high"
      />
    )}
    {preloadImage && !preloadImageWebp && (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        fetchpriority="high"
      />
    )}

    <!-- Podcast RSS auto-discovery (live Anchor feed) -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Inlet Wire Podcast"
      href="https://anchor.fm/s/10edfd0cc/podcast/rss"
    />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Inlet Wire" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:image" content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={resolvedOgAlt} />
    <!-- Article-specific Open Graph (episode pages) -->
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === "article" && (
      <meta property="article:author" content="https://inletwire.com/about/" />
    )}
    {ogType === "article" && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === "article" && articleTags && articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@inletwire" />
    <meta name="twitter:creator" content="@inletwire" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOg} />
    <meta name="twitter:image:alt" content={resolvedOgAlt} />

    <!-- Fonts & icon CDN preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.simpleicons.org" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@900&display=swap"
      rel="stylesheet"
    />

    {jsonLdArray.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MYS9YKGZ3B"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MYS9YKGZ3B');
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
