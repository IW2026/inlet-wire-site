---
import BaseLayout from "../layouts/BaseLayout.astro";

// Subject preselect happens client-side (see script below) — this is a
// static build, so Astro.url.searchParams is always empty at runtime.
const initialSubject = "General";

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home",    item: "https://inletwire.com/" },
    { "@type": "ListItem", position: 2, name: "Contact", item: "https://inletwire.com/contact/" },
  ],
};
---
<BaseLayout title="Contact — Press, Sponsorship & Artist Submissions" path="/contact/" description="Get in touch with Inlet Wire. Press, sponsorship, artist submissions, Waves & Wire tips, charity work. All welcome." jsonLd={[breadcrumbJsonLd]}>
  <section class="hero">
    <div class="container" style="text-align: center;">
      <h1>Get in touch</h1>
      <p class="lede" style="margin-inline: auto;">Press, sponsorship, artist submissions, Waves & Wire tips, charity work. All welcome.</p>
    </div>
  </section>

  <section>
    <div class="container prose">
      <!--
        Form action: the site uses Formspree as a free no-server form backend.
        Sign up at formspree.io, create a form, paste the form ID below.
        Submissions forward to contact@inletwire.com.
      -->
      <form
        action="https://formspree.io/f/xkokpvdw"
        method="POST"
        class="stack"
      >
        <div class="form-field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required />
        </div>
        <div class="form-field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />
        </div>
        <div class="form-field">
          <label for="subject">Subject</label>
          <select id="subject" name="subject">
            <option value="General" selected={initialSubject === "General"}>General</option>
            <option value="Artist" selected={initialSubject === "Artist"}>Artist submission</option>
            <option value="Press" selected={initialSubject === "Press"}>Press</option>
            <option value="Sponsorship" selected={initialSubject === "Sponsorship"}>Sponsorship or charity</option>
            <option value="Waves & Wire" selected={initialSubject === "Waves & Wire"}>Waves & Wire</option>
          </select>
        </div>
        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <input type="hidden" name="_subject" value="New Inlet Wire contact form message" />
        <button type="submit" class="btn">Send</button>
      </form>

      <p style="margin-top: 2.5rem;" class="text-muted">
        Prefer email? <a class="link" href="mailto:contact@inletwire.com">contact@inletwire.com</a>
      </p>
      <p style="margin-top: 1rem;" class="text-muted">
        Sending music? See <a class="link" href="/submit/">how to submit</a> first.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
// Preselect the subject from ?subject= — must run client-side on a static build.
const param = new URLSearchParams(location.search).get("subject");
if (param) {
  const select = document.getElementById("subject") as HTMLSelectElement | null;
  if (select && Array.from(select.options).some((o) => o.value === param)) {
    select.value = param;
  }
}
</script>
