---
// portfolio.astro — hidden, no layout, noindex everywhere
// Do NOT link to this page from any nav, footer, or other page.
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Eric Chan — Selected Work</title>

  <!-- ─── Bot & crawler protection ─────────────────────────────────────── -->
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
  <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
  <meta name="bingbot" content="noindex, nofollow" />

  <!-- ─── Fonts (matching Inlet Wire) ──────────────────────────────────── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@900&display=swap"
    rel="stylesheet"
  />

  <style>
    /* ── Design tokens — exact Inlet Wire palette ───────────────────────── */
    :root {
      --ink:          #0A0A0A;
      --paper:        #FFFFFF;
      --cream:        #F5F1EC;
      --muted:        #5A5A5A;
      --rule:         #E8E8E8;
      --font-display: "Montserrat", system-ui, -apple-system, sans-serif;
      --font-body:    "Inter", system-ui, -apple-system, sans-serif;
      --maxw:         1120px;
    }

    /* ── Reset ───────────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    html, body, h1, h2, h3, h4, p, ul, ol, li, figure, blockquote {
      margin: 0; padding: 0;
    }
    ul, ol { list-style: none; }
    img, svg, video, iframe { display: block; max-width: 100%; }
    button, input, select, textarea { font: inherit; color: inherit; }
    a { color: inherit; text-decoration: none; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

    /* ── Base ────────────────────────────────────────────────────────────── */
    body {
      background: var(--paper);
      color: var(--ink);
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.6;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    h1, h2, h3, h4 {
      font-family: var(--font-display);
      font-weight: 900;
      letter-spacing: -0.01em;
      line-height: 1.1;
    }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
    h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); }
    h3 { font-size: 1.25rem; }

    p + p { margin-top: 1rem; }

    /* ── Layout ──────────────────────────────────────────────────────────── */
    .container {
      width: 100%;
      max-width: var(--maxw);
      margin-inline: auto;
      padding-inline: 1.25rem;
    }

    /* ── Page header ─────────────────────────────────────────────────────── */
    .page-header {
      padding: 4rem 0 3.5rem;
      border-bottom: 1px solid var(--rule);
    }
    .page-name {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(3rem, 8vw, 5.5rem);
      letter-spacing: -0.03em;
      line-height: 1.0;
      color: var(--ink);
    }
    .page-title {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(2rem, 5vw, 3.25rem);
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--muted);
      margin-top: 0.4rem;
    }
    .page-subtitle {
      margin-top: 1rem;
      font-size: 0.95rem;
      color: var(--muted);
      letter-spacing: 0.02em;
    }

    /* ── Sections ────────────────────────────────────────────────────────── */
    .portfolio-section {
      padding: 4rem 0;
      border-bottom: 1px solid var(--rule);
    }
    .portfolio-section:last-of-type {
      border-bottom: none;
      padding-bottom: 6rem;
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
      margin-bottom: 0.65rem;
    }

    .section-heading {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(1.5rem, 3.5vw, 2.25rem);
      letter-spacing: -0.01em;
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }

    .section-rule {
      border: none;
      border-top: 1px solid var(--rule);
      margin: 0 0 1.75rem;
    }

    .section-intro {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--ink);
      max-width: 72ch;
      margin-bottom: 2.5rem;
    }

    /* ── Screenshot cards ────────────────────────────────────────────────── */
    .screenshot-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 640px) {
      .screenshot-grid { grid-template-columns: 1fr; }
    }

    .screenshot-card {
      display: block;
      border: 1px solid var(--rule);
      overflow: hidden;
      transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      background: var(--cream);
    }
    .screenshot-card:hover {
      border-color: var(--ink);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }
    .screenshot-img {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      object-position: top center;
      transition: transform 0.4s ease;
    }
    .screenshot-card:hover .screenshot-img {
      transform: scale(1.02);
    }
    .screenshot-caption {
      padding: 0.85rem 1.1rem;
      border-top: 1px solid var(--rule);
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .screenshot-caption-arrow {
      font-size: 0.85rem;
      font-weight: 400;
      letter-spacing: 0;
      text-transform: none;
      color: var(--ink);
      transition: transform 0.15s ease;
    }
    .screenshot-card:hover .screenshot-caption-arrow {
      transform: translateX(3px);
    }

    /* ── Embed stacks ────────────────────────────────────────────────────── */
    .embed-stack {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    /* ── Spotify embeds ──────────────────────────────────────────────────── */
    .spotify-embed-wrap {
      width: 100%;
    }
    .spotify-embed-wrap iframe {
      border-radius: 12px;
      border: 0;
      width: 100%;
      height: 152px;
    }

    /* ── Brand group labels (Advertising Scoring and Production) ────────── */
    .embed-brand-row {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
      margin-top: 3rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--rule);
    }
    .embed-brand-row:first-child {
      margin-top: 0;
    }
    .embed-brand {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(1.4rem, 3vw, 2rem);
      letter-spacing: -0.01em;
      color: var(--ink);
      line-height: 1;
    }
    .embed-brand-detail {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    /* ── Contact CTA section ─────────────────────────────────────────────── */
    .contact-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
      margin-bottom: 0.65rem;
    }
    .contact-heading {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(1.5rem, 3.5vw, 2.25rem);
      letter-spacing: -0.01em;
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }
    .contact-body {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--ink);
      max-width: 52ch;
      margin-bottom: 2rem;
    }
    .contact-email {
      display: inline-block;
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      letter-spacing: -0.01em;
      color: var(--ink);
      border-bottom: 2px solid var(--ink);
      padding-bottom: 3px;
      transition: opacity 0.15s ease;
    }
    .contact-email:hover {
      opacity: 0.55;
    }

    /* ── Sub-sections (Websites breakdown) ─────────────────────────────── */
    .subsection {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule);
    }
    .subsection-heading {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: -0.01em;
      line-height: 1.2;
      margin-bottom: 0.75rem;
      color: var(--ink);
    }
    .subsection p {
      font-size: 0.97rem;
      line-height: 1.75;
      color: var(--ink);
      max-width: 72ch;
    }
    .subsection-meta {
      margin-top: 1rem;
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .subsection-img-scroll {
      width: 100%;
      height: 420px;
      overflow-y: scroll;
      overflow-x: hidden;
      border: 1px solid var(--rule);
      margin-top: 1.25rem;
      -webkit-overflow-scrolling: touch;
    }
    .subsection-img-scroll::-webkit-scrollbar {
      width: 6px;
    }
    .subsection-img-scroll::-webkit-scrollbar-track {
      background: var(--cream);
    }
    .subsection-img-scroll::-webkit-scrollbar-thumb {
      background: var(--rule);
      border-radius: 3px;
    }
    .subsection-img-scroll::-webkit-scrollbar-thumb:hover {
      background: var(--muted);
    }
    .subsection-img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* ── YouTube embeds (responsive 16:9) ───────────────────────────────── */
    .video-wrap {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      overflow: hidden;
      background: var(--cream);
    }
    .video-wrap iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  </style>
</head>

<body>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="container">
      <h1 class="page-name">Eric Chan</h1>
      <p class="page-title">Selected Work</p>
      <p class="page-subtitle">Websites &nbsp;·&nbsp; Audio Engineering &nbsp;·&nbsp; Podcast &nbsp;·&nbsp; Advertising Scoring &amp; Production &nbsp;·&nbsp; Music Project</p>
    </div>
  </div>


  <!-- 01 — WEBSITES -->
  <section class="portfolio-section">
    <div class="container">
      <p class="section-label">01</p>
      <h2 class="section-heading">Websites</h2>
      <hr class="section-rule" />
      <p class="section-intro">
        For Inlet Wire, I built the website as a full media platform around the podcast. The
        work includes the homepage, episode archive, individual episode pages, transcripts,
        written articles, newsletter sign-up, social integration, and a contact page for
        submissions and sponsorship. I wanted the site to do more than hold audio. It had to
        help people find the artists, read more about the episodes, follow the project, and
        come back to the archive over time.
      </p>

      <div class="subsection">
        <h3 class="subsection-heading">1. Homepage and Brand Identity</h3>
        <p>The homepage introduces Inlet Wire with the line "Your direct line to BC artists." That line sets the tone for the whole project. I wrote the copy, designed the layout, and made sure a first-time visitor could understand immediately what Inlet Wire is and why it matters. The homepage features the latest episode up front, two clear navigation paths (latest episode and playlist), and a rotating episode cover that cycles through the archive. Everything on the page is there to help someone decide to listen.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/01_homepage_brand_identity.png" alt="Inlet Wire homepage" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Brand direction, copywriting, homepage layout, visual identity<br/><em>My role:</em> Concept, copy, design, build<br/><em>Skills:</em> Web design, brand communication, UX writing, front-end development</p>
      </div>

      <div class="subsection">
        <h3 class="subsection-heading">2. Episode Archive and Tag System</h3>
        <p>The episodes page is a browsable archive organized by genre, location, artist type, and role. Tags like indie-rock, singer-songwriter, studio, Vancouver, and producer let visitors filter by what they're looking for. I built this with long-term archive thinking in mind. As more episodes are added, the site becomes a real reference for BC music rather than just a feed. The grid layout keeps it scannable and the tag system makes it easy to find artists by context.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/02_episode_archive_and_tags.png" alt="Inlet Wire episodes archive and tag system" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Archive structure, taxonomy, long-term site planning<br/><em>My role:</em> Structure, design, content organization<br/><em>Skills:</em> Information architecture, navigation design, SEO-friendly content structure</p>
      </div>

      <div class="subsection">
        <h3 class="subsection-heading">3. Individual Episode Page</h3>
        <p>Each episode has its own page with the episode artwork, embedded Spotify player, platform links (Spotify, Apple Podcasts, YouTube, iHeart, Pocket Casts, Overcast, RSS), and a share option. The page is designed around the episode as its own object, not just a post in a feed. I set up the episode template so each new release comes out with a consistent structure and all the right distribution links in place.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/03_individual_episode_page_player_and_links.png" alt="Inlet Wire individual episode page" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Podcast publishing, audio distribution, episode packaging<br/><em>My role:</em> Template design, publishing setup, platform integration<br/><em>Skills:</em> Podcast publishing, web content management, multi-platform distribution</p>
      </div>

      <div class="subsection">
        <h3 class="subsection-heading">4. Transcript, Artist Links, and Episode Navigation</h3>
        <p>Below the player, each episode page includes a full transcript, direct links to the artist's platforms (website, Instagram, Bandcamp, etc.), follow links for Inlet Wire, and previous/next episode navigation. The transcript makes each episode accessible and searchable. The artist links turn the episode into a useful resource for anyone discovering a band for the first time. The navigation keeps people moving through the archive instead of leaving.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/04_transcript_artist_links_and_navigation.png" alt="Inlet Wire transcript, artist links and navigation" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Accessibility, SEO, internal navigation, artist discovery<br/><em>My role:</em> Page structure, transcript publishing, content linking<br/><em>Skills:</em> Accessibility, on-page SEO, content architecture, audience retention</p>
      </div>

      <div class="subsection">
        <h3 class="subsection-heading">5. Editorial Articles</h3>
        <p>For each episode, I write an editorial article that gives the conversation another life outside the audio. The Silverware piece is a good example — it's not a transcript and it's not a summary. It's a written piece that takes the key ideas from the conversation and puts them into a form that works on its own. This gives the episode a second entry point for people who find it through search or social, and it builds a written record of BC music alongside the audio archive.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/05_editorial_article_page.png" alt="Inlet Wire editorial article page" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Editorial writing, storytelling, audience development<br/><em>My role:</em> Writer, editor<br/><em>Skills:</em> Editorial writing, interview-to-article adaptation, publishing</p>
      </div>

      <div class="subsection">
        <h3 class="subsection-heading">6. Newsletter and Instagram Integration</h3>
        <p>The site connects the podcast to a newsletter and an Instagram feed. The newsletter sign-up is placed at the bottom of the homepage and in the footer. The Instagram section pulls in the @inletwire feed and links directly to the account. This keeps the audience connected between episodes and gives the project a consistent presence across channels. I also set up the visual promo system on Instagram to support each episode release with graphics built around the episode artwork.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/06_newsletter_and_instagram_integration.png" alt="Inlet Wire newsletter and Instagram integration" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Audience growth, social integration, community connection<br/><em>My role:</em> Strategy, design, setup, content<br/><em>Skills:</em> Email marketing setup, social media integration, visual content production</p>
      </div>

      <div class="subsection">
        <h3 class="subsection-heading">7. Random Episode Feature</h3>
        <p>The homepage includes a "Drop in on a random episode" feature that serves up a different episode each time and lets visitors shuffle to another. This keeps older episodes discoverable and gives new visitors an easy way into the archive without having to start from episode one. It's a small UX detail but it makes a real difference for a catalog that's always growing.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/07_random_episode_discovery_feature.png" alt="Inlet Wire random episode feature" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> User experience thinking, archive discoverability<br/><em>My role:</em> Concept, build<br/><em>Skills:</em> UX design, front-end development, content discovery</p>
      </div>

      <div class="subsection" style="margin-bottom: 2.5rem;">
        <h3 class="subsection-heading">8. Contact Page and Industry Readiness</h3>
        <p>The contact page is set up for press, sponsorship inquiries, artist submissions, tips for the Waves &amp; Wire section, and charity work. There's a form with a subject dropdown and a direct email option. This makes the project ready for real-world use beyond a student portfolio — Inlet Wire is built to operate as a professional media outlet.</p>
        <div class="subsection-img-scroll"><img class="subsection-img" src="/images/portfolio/08_contact_page_and_media_kit.png" alt="Inlet Wire contact page" loading="lazy" /></div>
        <p class="subsection-meta"><em>What this shows:</em> Professional readiness, industry-facing communication<br/><em>My role:</em> Copy, design, form setup<br/><em>Skills:</em> Professional web publishing, contact management, industry communication</p>
      </div>

      <div class="screenshot-grid">

        <a
          class="screenshot-card"
          href="https://inletwire.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit Inlet Wire — home"
        >
          <img
            class="screenshot-img"
            src="/images/portfolio/screenshot-home.png"
            alt="Inlet Wire — home page"
            width="1200"
            height="750"
            loading="lazy"
          />
          <div class="screenshot-caption">
            <span>inletwire.com — Home</span>
            <span class="screenshot-caption-arrow">↗</span>
          </div>
        </a>

        <a
          class="screenshot-card"
          href="https://inletwire.com/episodes/leah-abramson/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit Inlet Wire — episode page"
        >
          <img
            class="screenshot-img"
            src="/images/portfolio/screenshot-episodes.png"
            alt="Inlet Wire — episodes page"
            width="1200"
            height="750"
            loading="lazy"
          />
          <div class="screenshot-caption">
            <span>inletwire.com — Episode</span>
            <span class="screenshot-caption-arrow">↗</span>
          </div>
        </a>

      </div>
    </div>
  </section>


  <!-- 02 — AUDIO ENGINEERING -->
  <section class="portfolio-section">
    <div class="container">
      <p class="section-label">02</p>
      <h2 class="section-heading">Audio Engineering</h2>
      <hr class="section-rule" />
      <p class="section-intro">
        I record, mix, and master for indie bands and artists across Taiwan, Hong Kong, and
        Macau, with a focus on experimental and alternative music. Day's Eye Records, my
        independent label founded in 2009, has released work across the region. In 2024, I
        established GenLab in Taichung as a dedicated studio and experimental music space. I
        work openly with artists to understand their creative vision, using arrangement,
        production techniques, and audio tools to realize what they're hearing. Artists and
        projects I've worked with have been recognized at the Macao TDM music awards and
        ranked in the top one hundred at the Freshmusic Awards across multiple years.
      </p>

